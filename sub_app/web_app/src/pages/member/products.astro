import MemberProductsPage from "@/components/member/products/ProductsPage"

const locale = Astro.url.pathname.startsWith("/en/") ? "en" : Astro.url.pathname.startsWith("/id/") ? "id" : undefined;
---

<MemberLayout title="Products" subtitle="Kelola product milik member" locale={locale}>
