---
import MemberLayout from "../../../layouts/MemberLayout.astro";
import MemberDashboardPage from "../../../components/member/dashboard/MemberDashboardPage";

const locale = Astro.params.lang === "en" ? "en" : "id";
export const prerender = false;
---

<MemberLayout title={locale === "en" ? "Member Dashboard" : "Dasbor Member"} subtitle={locale === "en" ? "Store and daily operations overview." : "Ringkasan toko dan operasional harian."} locale={locale}>
  <MemberDashboardPage client:load locale={locale} />
</MemberLayout>