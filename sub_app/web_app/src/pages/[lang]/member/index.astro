---
import MemberLayout from "../../../layouts/MemberLayout.astro";

const locale = Astro.params.lang ?? "id";
export const prerender = false;
---

<MemberLayout title="Member Dashboard" subtitle="Ringkasan toko dan operasional harian." locale={locale}>
  <section id="overview" class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Total Produk</p>
      <p class="mt-2 text-2xl font-semibold text-slate-900">128</p>
      <p class="mt-1 text-sm text-slate-500">12 produk aktif hari ini</p>
    </article>
    <article class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Order Masuk</p>
      <p class="mt-2 text-2xl font-semibold text-slate-900">24</p>
      <p class="mt-1 text-sm text-slate-500">7 menunggu diproses</p>
    </article>
    <article class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Stok Rendah</p>
      <p class="mt-2 text-2xl font-semibold text-slate-900">5</p>
      <p class="mt-1 text-sm text-slate-500">Butuh restock segera</p>
    </article>
    <article class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-4 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Pendapatan</p>
      <p class="mt-2 text-2xl font-semibold text-slate-900">Rp 18,4jt</p>
      <p class="mt-1 text-sm text-slate-500">Estimasi minggu ini</p>
    </article>
  </section>

  <section class="grid gap-6 lg:grid-cols-[1.4fr_0.9fr]">
    <div id="orders" class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h3 class="text-base font-semibold text-slate-900">Order Terbaru</h3>
          <p class="mt-1 text-sm text-slate-500">Pesanan yang perlu diproses oleh member.</p>
        </div>
        <a href="#reports" class="text-sm font-semibold text-emerald-700 hover:text-emerald-800">Lihat laporan</a>
      </div>
      <div class="mt-4 space-y-3">
        <div class="flex items-center justify-between rounded-xl border border-[#eee6dc] bg-[#fcfbf8] px-4 py-3 text-sm">
          <div>
            <p class="font-semibold text-slate-900">#ORD-1024</p>
            <p class="text-slate-500">2 item · Menunggu packing</p>
          </div>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800">Pending</span>
        </div>
        <div class="flex items-center justify-between rounded-xl border border-[#eee6dc] bg-[#fcfbf8] px-4 py-3 text-sm">
          <div>
            <p class="font-semibold text-slate-900">#ORD-1023</p>
            <p class="text-slate-500">5 item · Sudah dibayar</p>
          </div>
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800">Ready</span>
        </div>
        <div class="flex items-center justify-between rounded-xl border border-[#eee6dc] bg-[#fcfbf8] px-4 py-3 text-sm">
          <div>
            <p class="font-semibold text-slate-900">#ORD-1022</p>
            <p class="text-slate-500">1 item · Perlu validasi</p>
          </div>
          <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-800">Review</span>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <section id="store" class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-5 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">Status Toko</h3>
        <p class="mt-2 text-sm text-slate-600">Toko aktif, verifikasi lengkap, dan katalog siap jual.</p>
        <div class="mt-4 flex items-center justify-between rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
          <span>Operasional normal</span>
          <span class="font-semibold">98%</span>
        </div>
      </section>

      <section id="settings" class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-5 shadow-sm">
        <h3 class="text-base font-semibold text-slate-900">Akses Cepat</h3>
        <div class="mt-4 grid gap-3">
          <a href="#products" class="rounded-xl border border-[#e8e0d6] bg-[#fcfbf8] px-4 py-3 text-sm font-semibold text-slate-800 hover:border-emerald-200 hover:bg-emerald-50">Kelola produk</a>
          <a href="#orders" class="rounded-xl border border-[#e8e0d6] bg-[#fcfbf8] px-4 py-3 text-sm font-semibold text-slate-800 hover:border-emerald-200 hover:bg-emerald-50">Proses order</a>
          <a href="#reports" class="rounded-xl border border-[#e8e0d6] bg-[#fcfbf8] px-4 py-3 text-sm font-semibold text-slate-800 hover:border-emerald-200 hover:bg-emerald-50">Lihat laporan</a>
        </div>
      </section>
    </div>
  </section>

  <section id="reports" class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-5 shadow-sm">
    <h3 class="text-base font-semibold text-slate-900">Ringkasan Aktivitas</h3>
    <p class="mt-2 text-sm text-slate-600">Dashboard member sekarang mengikuti pola layout admin, tetapi tetap memakai nuansa warna hangat yang sudah ada.</p>
  </section>

  <section id="products" class="rounded-2xl border border-[#e8e0d6] bg-white/80 p-5 shadow-sm">
    <h3 class="text-base font-semibold text-slate-900">Produk Terlaris</h3>
    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      <div class="rounded-xl border border-[#eee6dc] bg-[#fcfbf8] p-4">
        <p class="text-sm font-semibold text-slate-900">Kemeja Linen</p>
        <p class="mt-1 text-sm text-slate-500">48 unit terjual</p>
      </div>
      <div class="rounded-xl border border-[#eee6dc] bg-[#fcfbf8] p-4">
        <p class="text-sm font-semibold text-slate-900">Tas Canvas</p>
        <p class="mt-1 text-sm text-slate-500">31 unit terjual</p>
      </div>
      <div class="rounded-xl border border-[#eee6dc] bg-[#fcfbf8] p-4">
        <p class="text-sm font-semibold text-slate-900">Sepatu Casual</p>
        <p class="mt-1 text-sm text-slate-500">26 unit terjual</p>
      </div>
    </div>
  </section>
</MemberLayout>