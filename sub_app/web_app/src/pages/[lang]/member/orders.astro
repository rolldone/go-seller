---
import MemberLayout from "../../../layouts/MemberLayout.astro";
import MemberOrdersPage from "../../../components/member/orders/OrdersPage";

const locale = Astro.params.lang === "en" ? "en" : "id";
export const prerender = false;
---

<MemberLayout title={locale === "en" ? "Orders" : "Orders"} subtitle={locale === "en" ? "Store order monitoring." : "Monitoring order per toko."} locale={locale}>
	<MemberOrdersPage client:load />
</MemberLayout>