---
import "../../../styles/front.css";
import MemberSetupPage from "@/components/member/MemberSetupPage"

const locale = Astro.params.lang;
export const prerender = false;
---

<html lang={locale ?? "id"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Member Setup | GoSeller</title>
  </head>
  <body class="bg-[#f7f7f5]">
    <MemberSetupPage client:only="react" locale={locale} />
  </body>
</html>