---
export const prerender = false;

import "../../styles/front.css";
import StoreFrontHome from "../../components/front/StoreFrontHome";
import CustomerSessionBootstrap from "../../components/customer/CustomerSessionBootstrap.astro";
import { normalizeLocale } from "../../lib/siteLocale";
import { useTranslations } from "../../i18n";

const locale = normalizeLocale(Astro.params.lang);
const customerSession = Astro.locals.customerSession ?? null;
const t = useTranslations("common", locale);
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{t("storefrontTitle", "Go Seller Storefront")}</title>
		<CustomerSessionBootstrap session={customerSession} />
	</head>
	<body class="bg-[#f7f7f5] text-slate-900 antialiased">
		<StoreFrontHome client:load customerSession={customerSession} locale={locale} />
	</body>
</html>