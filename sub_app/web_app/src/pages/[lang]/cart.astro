---
export const prerender = false;

import "../../styles/front.css";
import CartPage from "@/components/front/CartPage"
import { buildBusinessStore } from "@/pages/b/store"
import CustomerSessionBootstrap from "@/components/customer/CustomerSessionBootstrap.astro"
import { normalizeLocale } from "@/lib/siteLocale"

const locale = normalizeLocale(Astro.params.lang);
const customerSession = Astro.locals.customerSession ?? null;
const businessSlug = typeof Astro.url.searchParams.get("business_slug") === "string"
  ? Astro.url.searchParams.get("business_slug")
  : null;
const business = businessSlug ? (await buildBusinessStore(businessSlug, locale)).store.business : null;
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Keranjang Belanja | GoSeller</title>
		<CustomerSessionBootstrap session={customerSession} />
	</head>
	<body class="bg-[#f7f7f5] text-slate-900 antialiased">
		<CartPage client:only="react" customerSession={customerSession} business={business} />
	</body>
</html>