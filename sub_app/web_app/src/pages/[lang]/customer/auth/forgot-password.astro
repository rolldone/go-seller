---
export const prerender = false;

import "../../../../styles/front.css";
import ForgotPasswordPage from "../../../../components/customer/auth/ForgotPasswordPage";
import CustomerSessionBootstrap from "../../../../components/customer/CustomerSessionBootstrap.astro";
import { normalizeLocale } from "../../../../lib/siteLocale";
import { useTranslations } from "../../../../i18n";

const customerSession = Astro.locals.customerSession ?? null;
const locale = normalizeLocale(Astro.params.lang);
const t = useTranslations("auth", locale);
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{t("forgotTitle", "Lupa Password")} | {t("goSeller", "GoSeller")}</title>
		<CustomerSessionBootstrap session={customerSession} />
	</head>
	<body>
		<ForgotPasswordPage client:only="react" locale={locale} />
	</body>
</html>