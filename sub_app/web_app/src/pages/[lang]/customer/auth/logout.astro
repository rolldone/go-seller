---
export const prerender = false;

import "../../../../styles/front.css";
import { buildLocalizedPath, normalizeLocale } from "@/lib/siteLocale"

const locale = normalizeLocale(Astro.params.lang);
const apiUrl = import.meta.env.PUBLIC_API_URL ? String(import.meta.env.PUBLIC_API_URL).replace(/\/$/, "") : "";
const loginUrl = buildLocalizedPath("/customer/auth/login", locale);
const customerSession = Astro.locals.customerSession ?? null;
---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Logout | GoSeller</title>
		<meta name="customer-authenticated" content={customerSession?.authenticated ? "true" : "false"} />
	</head>
	<body>
		<script is:inline define:vars={{ apiUrl, loginUrl }}>
			(async () => {
				try {
					const token = localStorage.getItem("customer_access_token");
					if (apiUrl) {
						await fetch(`${apiUrl}/api/customer/auth/logout`, {
							method: "POST",
							credentials: "include",
							headers: token ? { Authorization: `Bearer ${token}` } : {},
						});
					}
				} catch (e) {
					// ignore logout errors and continue redirecting
				} finally {
					localStorage.removeItem("customer_access_token");
					localStorage.removeItem("customer_refresh_token");
					localStorage.removeItem("customer_profile");
					document.cookie = "customer_access_token=; path=/; max-age=0; samesite=lax";
					document.cookie = "customer_profile=; path=/; max-age=0; samesite=lax";
					window.location.replace(loginUrl);
				}
			})();
		</script>
	</body>
</html>