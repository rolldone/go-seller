---
import "../styles/front.css";
import StoreFrontHome from "@/components/front/StoreFrontHome"
import CustomerSessionBootstrap from "@/components/customer/CustomerSessionBootstrap.astro"
import MaintenanceNotice from "@/components/front/MaintenanceNotice.astro"
import { fetchStoreMaintenanceInfo } from "@/lib/storeMaintenance"
import type { CartBusinessSummary } from "@/lib/cartApi"

const customerSession = Astro.locals.customerSession ?? null;
const apiBase = import.meta.env.PUBLIC_API_URL ? String(import.meta.env.PUBLIC_API_URL).replace(/\/$/, "") : "";

async function fetchWithTimeout(input: RequestInfo | URL, init: RequestInit = {}, timeoutMs = 1500): Promise<Response> {
	const controller = typeof AbortController !== "undefined" ? new AbortController() : null;
	const timeout = controller ? setTimeout(() => controller.abort(), timeoutMs) : null;
	try {
		return await fetch(input, { ...init, signal: controller?.signal ?? init.signal });
	} finally {
		if (timeout) clearTimeout(timeout);
	}
}

async function loadCartBusinesses(session: typeof customerSession): Promise<CartBusinessSummary[]> {
	if (!apiBase || !session?.authenticated || !session.accessToken) return [];
	try {
		const res = await fetchWithTimeout(`${apiBase}/api/order/carts/me/businesses`, {
			method: "GET",
			headers: {
				Authorization: `Bearer ${session.accessToken}`,
			},
		});
		if (!res.ok) return [];
		const payload = (await res.json().catch(() => ({}))) as { data?: CartBusinessSummary[] };
		return Array.isArray(payload?.data) ? payload.data : [];
	} catch {
		return [];
	}
}

const maintenance = await fetchStoreMaintenanceInfo({ baseUrl: Astro.url.origin, fetchImpl: fetch });
const initialBusinesses = maintenance.index ? [] : await loadCartBusinesses(customerSession);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Go Seller Storefront</title>
		<CustomerSessionBootstrap session={customerSession} />
	</head>
	<body class="bg-[#f7f7f5] text-slate-900 antialiased">
		{maintenance.index ? (
			<MaintenanceNotice
				title="Beranda sedang dalam maintenance"
				description="Halaman beranda sedang ditutup sementara. Silakan kembali lagi nanti."
			/>
		) : (
			<StoreFrontHome client:load customerSession={customerSession} initialBusinesses={initialBusinesses} />
		)}
	</body>
</html>
