---
import "../styles/front.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>GoSeller · B</title>
  </head>
  <body class="bg-[#f7f7f5] text-slate-900 antialiased">
    <main class="flex min-h-screen flex-col items-center justify-center px-4 text-center">
      <p class="text-xs uppercase tracking-[0.4em] text-slate-500">GoSeller</p>
      <h1 class="mt-3 text-4xl font-semibold text-slate-900 sm:text-5xl">B · Bisnis</h1>
      <p class="mt-4 max-w-2xl text-base text-slate-600">
        Halaman ini dibuat khusus untuk memudahkan akses cepat ke area bisnis. Tambahkan konten spesial di sini kapan pun diperlukan.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="rounded-2xl border border-slate-300 bg-white px-5 py-2 text-sm font-semibold text-slate-800 transition hover:border-slate-400"
        >
          Kembali ke Beranda
        </a>
        <a
          href="/customer/dashboard"
          class="rounded-2xl bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
        >
          Dashboard Customer
        </a>
      </div>
    </main>
  </body>
</html>
