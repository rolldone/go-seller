---
export const prerender = false;

import "../styles/front.css";
import BusinessPageNav from "@/components/front/business/BusinessPageNav"
import Footer from "@/components/front/Footer"
import CategoryStoreFrontPage from "@/components/front/categories/CategoryStoreFrontPage"
import CustomerSessionBootstrap from "@/components/customer/CustomerSessionBootstrap.astro"
import { normalizeLocale } from "@/lib/siteLocale"
import { fetchRootCategories } from "@/lib/categoryPageData"
import { fetchPublicProductsPage, fetchPublicBusinesses, buildBrowseData } from "@/components/front/products/api"

const locale = normalizeLocale("id");
const customerSession = Astro.locals.customerSession ?? null;
const initialPage = Math.max(1, Number(Astro.url.searchParams.get("page") || "1") || 1);
const initialCategoryIDs = String(Astro.url.searchParams.get("category_ids") || "")
  .split(",")
  .map((value) => value.trim())
  .filter(Boolean);

const roots = await fetchRootCategories({ locale, fetchImpl: fetch }).catch(() => []);
const categoryName = locale === "en" ? "Categories" : "Kategori";

// Server-side initial products (general, no category filter)
const PRODUCT_PER_PAGE = 12;
const productsPayload = await fetchPublicProductsPage({
  locale,
  page: initialPage,
  limit: PRODUCT_PER_PAGE,
  categoryIDs: initialCategoryIDs.length > 0 ? initialCategoryIDs : undefined,
}).catch(() => ({ items: [], total: 0 }));
const businesses = await fetchPublicBusinesses().catch(() => []);
const browse = buildBrowseData(productsPayload.items || [], businesses);
const serverTotalProducts = Math.max(0, Number(productsPayload.total) || (productsPayload.items || []).length);
const serverTotalPages = Math.max(1, Math.ceil(serverTotalProducts / PRODUCT_PER_PAGE));
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{categoryName} | GoSeller</title>
    <CustomerSessionBootstrap session={customerSession} />
  </head>
  <body class="bg-[#f7f7f5] text-slate-900 antialiased">
    <div class="relative min-h-screen overflow-x-hidden bg-[#f7f7f5]">
      <div class="relative mx-auto flex min-h-screen w-full max-w-7xl flex-col px-4 pb-12 pt-6 sm:px-6 lg:px-8">
        <BusinessPageNav client:load business={null} customerSession={customerSession} locale={locale} />

        <main class="mt-10 flex-1 space-y-12 pb-8">
          <CategoryStoreFrontPage
            client:load
            locale={locale}
            categoryName={categoryName}
            childCategories={roots.map((item) => ({ id: String(item.id), name: String(item.name || "Kategori"), slug: String(item.slug || "") }))}
            products={browse.products}
            initialProductPage={initialPage}
            initialSelectedChildCategoryIDs={initialCategoryIDs}
            serverTotalPages={serverTotalPages}
            serverTotalProducts={serverTotalProducts}
          />
        </main>
      </div>
      <Footer client:load locale={locale} />
    </div>
  </body>
</html>
