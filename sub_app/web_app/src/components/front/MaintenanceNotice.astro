---
const { title, description } = Astro.props as {
  title: string;
  description: string;
};
---
<div class="min-h-screen bg-[#f7f7f5] text-slate-900 antialiased">
  <div class="mx-auto flex min-h-screen max-w-4xl flex-col items-center justify-center px-6 py-20 text-center">
    <div class="rounded-3xl border border-slate-200 bg-white p-10 shadow-md">
      <div class="mb-6 inline-flex rounded-full bg-amber-100 px-4 py-2 text-sm font-semibold text-amber-800">
        Maintenance Mode
      </div>
      <h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">{title}</h1>
      <p class="mt-4 max-w-xl text-sm leading-7 text-slate-600">{description}</p>
      <div class="mt-8 rounded-2xl bg-slate-50 p-5 text-left text-sm text-slate-500">
        <p>Tim kami sedang melakukan pemeliharaan. Silakan kembali lagi nanti.</p>
      </div>
    </div>
  </div>
</div>
