---
import "../styles/admin.css";
import AdminLogoutButton from "../components/admin/AdminLogoutButton";
import AdminAuthGuard from "../components/admin/AdminAuthGuard";
import AlertContainer from "../components/ui/AlertContainer";

interface Props {
  title?: string;
}

const { title = "Admin Dashboard" } = Astro.props;
const pathname = Astro.url.pathname;

const menus = [
  { href: "/admin", label: "Dashboard", icon: "dashboard", group: "general" },
  { href: "/admin/users", label: "Users", icon: "users", group: "general" },
  { href: "/admin/customers", label: "Customers", icon: "customers", group: "general" },
  { href: "/admin/orders", label: "Orders", icon: "orders", group: "sales" },
  { href: "/admin/pos", label: "POS", icon: "pos", group: "sales" },
  { href: "/admin/payment-providers", label: "Payment Providers", icon: "payments", group: "sales" },
  { href: "/admin/products", label: "Products", icon: "products", group: "catalog" },
  { href: "/admin/variations", label: "Variations", icon: "products", group: "catalog" },
  { href: "/admin/businesses", label: "Businesses", icon: "businesses", group: "catalog" },
  { href: "/admin/attribute-groups", label: "Attribute Groups", icon: "categories", group: "catalog" },
  { href: "/admin/attributes", label: "Attributes", icon: "tags", group: "catalog" },
  { href: "/admin/categories", label: "Categories", icon: "categories", group: "catalog" },
  { href: "/admin/tags", label: "Tags", icon: "tags", group: "catalog" },
  { href: "/admin/assets", label: "Assets", icon: "assets", group: "catalog" },
  { href: "/admin/coupons", label: "Coupons", icon: "coupons", group: "marketing" },
  { href: "/admin/discounts", label: "Discounts", icon: "discounts", group: "marketing" },
  { href: "/admin/settings", label: "Settings", icon: "settings", group: "access" },
  { href: "/admin/notifications", label: "Notifications", icon: "settings", group: "access" },
  { href: "/admin/admins", label: "Users & Roles", icon: "admins", group: "access" },
];

const menuGroups = [
  { key: "general", label: "General" },
  { key: "sales", label: "Sales" },
  { key: "catalog", label: "Catalog" },
  { key: "marketing", label: "Marketing" },
  { key: "access", label: "Access" },
];

const groupedMenus = menuGroups
  .map((group) => ({
    ...group,
    items: menus.filter((menu) => menu.group === group.key),
  }))
  .filter((group) => group.items.length > 0);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <div class="grid min-h-screen grid-cols-1 md:grid-cols-[240px_1fr]">
      <aside class="hidden border-r border-slate-200 bg-white md:block">
        <div class="border-b border-slate-200 px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Control Plane</p>
          <h1 class="mt-1 text-lg font-semibold text-slate-900">Admin Panel</h1>
        </div>

        <nav class="px-3 py-4">
          <div class="space-y-4">
            {groupedMenus.map((group) => (
              <section>
                <div class="flex items-center justify-between px-3">
                  <p class="pb-1 text-[11px] font-semibold uppercase tracking-wide text-slate-400">{group.label}</p>
                  <button
                    class="group rounded px-2 py-1 text-xs text-slate-500 hover:bg-slate-100"
                    data-toggle={group.key}
                    aria-expanded="true"
                    type="button"
                  >
                    <svg class="h-3 w-3 transition-transform group-hover:text-slate-700" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                      <path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
                <ul class="space-y-1" data-group={group.key}>
                  {group.items.map((menu) => {
                    const isActive =
                      menu.href === "/admin"
                        ? pathname === "/admin"
                        : pathname === menu.href || pathname.startsWith(`${menu.href}/`);
                    return (
                      <li>
                        <a
                          href={menu.href}
                          aria-current={isActive ? "page" : undefined}
                          class:list={[
                            "block rounded-lg px-3 py-2 text-sm font-medium transition",
                            isActive ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100",
                          ]}
                        >
                    {menu.icon === "dashboard" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <rect x="3" y="3" width="8" height="8" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="13" y="3" width="8" height="4" rx="1" stroke="currentColor" stroke-width="1.5"/>
                        <rect x="13" y="9" width="8" height="12" rx="1" stroke="currentColor" stroke-width="1.5"/>
                      </svg>
                    )}

                    {menu.icon === "products" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M4 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M8 11h8M8 15h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "businesses" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M4 20V7l8-3 8 3v13" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                        <path d="M9 10h1M9 14h1M14 10h1M14 14h1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "users" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <circle cx="8" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M3 19c0-2.5 2.5-4 5-4s5 1.5 5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <path d="M15 8h6M18 5v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "customers" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <circle cx="8" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M3 20c0-2.5 2.5-4 5-4s5 1.5 5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="17" cy="10" r="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M13 20c0-1.5 1.5-2.5 3.5-2.5s3.5 1 3.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "orders" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M8 9h8M8 13h8M8 17h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "pos" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7 9h10M7 13h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <path d="M16 15h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "categories" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M4 8h16M4 12h16M4 16h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
                      </svg>
                    )}

                    {menu.icon === "tags" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M4 12l8-8 8 8-8 8-8-8z" stroke="currentColor" stroke-width="1.5"/>
                        <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
                      </svg>
                    )}

                    {menu.icon === "coupons" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M9 15L15 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="9.5" cy="9.5" r="1" fill="currentColor"/>
                        <circle cx="14.5" cy="14.5" r="1" fill="currentColor"/>
                        <path d="M3 9.5V5a2 2 0 0 1 2-2h4.5l9 9-7 7-9-9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                      </svg>
                    )}

                    {menu.icon === "discounts" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <path d="M4 8V5a2 2 0 0 1 2-2h5l9 9-6 6-10-10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="7" cy="7" r="1" fill="currentColor"/>
                        <path d="M10 13l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "assets" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7 15l3-3 2 2 3-4 2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="8" cy="8" r="1.3" fill="currentColor"/>
                      </svg>
                    )}

                    {menu.icon === "admins" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M2 18c0-2 2.5-3.5 6-3.5s6 1.5 6 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="16" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M12 18c0-1.5 1.5-2.5 4-2.5s4 1 4 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.icon === "settings" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9V20a2 2 0 1 1-4 0v-.2a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6H4a2 2 0 1 1 0-4h.2a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1 1 0 0 0 1.1.2h.1a1 1 0 0 0 .6-.9V4a2 2 0 1 1 4 0v.2a1 1 0 0 0 .6.9h.1a1 1 0 0 0 1.1-.2l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1 1 0 0 0-.2 1.1v.1a1 1 0 0 0 .9.6H20a2 2 0 1 1 0 4h-.2a1 1 0 0 0-.9.6V15z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    )}

                    {menu.icon === "payments" && (
                      <svg class="-mt-0.5 mr-2 inline h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden>
                        <rect x="3" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M3 10h18" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7 14h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    )}

                    {menu.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </section>
            ))}
          </div>
        </nav>
      </aside>

      <div class="flex min-h-screen flex-col">
        <header class="sticky top-0 z-10 border-b border-slate-200 bg-white/95 backdrop-blur">
          <div class="flex items-center gap-3 px-4 py-3 sm:px-6">
            <div>
              <p class="text-xs uppercase tracking-wide text-slate-500">Admin</p>
              <h2 class="text-sm font-semibold text-slate-900">{title}</h2>
            </div>
            <AdminLogoutButton client:load />
          </div>
        </header>

        <main class="flex-1 px-4 py-6 sm:px-6">
          <slot />
        </main>
      </div>
    </div>

    <AdminAuthGuard client:load />
    <AlertContainer client:load />
    <style>
      .admin-group-collapse {
        overflow: hidden;
        transition: max-height 240ms ease;
      }
      .admin-toggle svg {
        transition: transform 200ms ease;
        transform-origin: 50% 50%;
      }
      .admin-toggle[aria-expanded="false"] svg {
        transform: rotate(-90deg);
      }
      .admin-toggle[aria-expanded="true"] svg {
        transform: rotate(0deg);
      }
    </style>
    <script>
      (function () {
        const defaults = { general: true, catalog: true, marketing: false, access: false };
        const getState = (key) => {
          try {
            const v = localStorage.getItem(`admin_menu_group_${key}`);
            if (v === null) return defaults[key] ?? false;
            return v === '1';
          } catch (e) {
            return defaults[key] ?? false;
          }
        };
        const setState = (key, val) => {
          try { localStorage.setItem(`admin_menu_group_${key}`, val ? '1' : '0'); } catch (e) {}
        };

        const collapse = (el) => {
          el.style.maxHeight = el.scrollHeight + 'px';
          // force repaint
          void el.offsetHeight;
          requestAnimationFrame(() => {
            el.style.maxHeight = '0px';
          });
        };

        const expand = (el) => {
          el.style.maxHeight = el.scrollHeight + 'px';
          const onEnd = () => {
            el.style.maxHeight = '';
            el.removeEventListener('transitionend', onEnd);
          };
          el.addEventListener('transitionend', onEnd);
        };

        const setGroup = (key, show) => {
          const list = document.querySelector(`[data-group="${key}"]`);
          const btn = document.querySelector(`[data-toggle="${key}"]`);
          if (!list || !btn) return;
          list.classList.add('admin-group-collapse');
          if (show) {
            expand(list);
            btn.setAttribute('aria-expanded', 'true');
          } else {
            collapse(list);
            btn.setAttribute('aria-expanded', 'false');
          }
          setState(key, show);
        };

        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('[data-toggle]').forEach((b) => {
            const key = b.getAttribute('data-toggle');
            b.classList.add('admin-toggle');
            b.addEventListener('click', () => {
              const list = document.querySelector(`[data-group="${key}"]`);
              if (!list) return;
              const expanded = b.getAttribute('aria-expanded') === 'true';
              setGroup(key, !expanded);
            });
          });

          // apply initial state
          document.querySelectorAll('[data-group]').forEach((el) => {
            const key = el.getAttribute('data-group');
            const show = getState(key);
            el.classList.add('admin-group-collapse');
            if (show) {
              el.style.maxHeight = el.scrollHeight + 'px';
              // allow transition to settle, then clear maxHeight
              setTimeout(() => { el.style.maxHeight = ''; }, 300);
              const btn = document.querySelector(`[data-toggle="${key}"]`);
              if (btn) btn.setAttribute('aria-expanded', 'true');
            } else {
              el.style.maxHeight = '0px';
              const btn = document.querySelector(`[data-toggle="${key}"]`);
              if (btn) btn.setAttribute('aria-expanded', 'false');
            }
          });
        });
      })();
    </script>
  </body>
</html>
