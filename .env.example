# Example environment variables for local/dev. Copy to `.env` and update secrets.

# App
APP_NAME=Go Seller
APP_ENV=development
PORT=8080
APP_URL=http://localhost:3651
ADMIN_URL=http://localhost:5173
FRONT_URL=http://localhost:4321

# Database (app-level)
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go_seller_db

# Docker/Postgres (used by docker-compose)
# Set POSTGRES_* so docker-compose can pass them into the postgres container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=go_seller_db

# JWT / Auth
AUTH_JWT_SECRET=change_me_to_a_strong_secret
JWT_ACCESS_EXP_SECONDS=900
JWT_REFRESH_EXP_SECONDS=1209600

# KeyDB / Redis
KEYDB_HOST=keydb
KEYDB_PORT=6379
KEYDB_PASS=
KEYDB_DB=0

# SMTP (example)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=admin@example.com
SMTP_USE_TLS=true

# Misc
LOG_LEVEL=info
DOCKER_HOST_IP=127.0.0.1
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:4321"

# PGAdmin defaults (for docker-compose)
PGADMIN_DEFAULT_EMAIL=donny.rolanda@gmail.com

# Storage (local atau S3)
# Driver: "local" untuk filesystem lokal, "s3" untuk S3/MinIO
STORAGE_DRIVER=local
STORAGE_ROOT=./storage
STORAGE_PUBLIC_URL=http://localhost:8080/assets

# S3 config (hanya digunakan jika STORAGE_DRIVER=s3)
# S3_BUCKET=my-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=  # optional, untuk MinIO atau S3-compat lainnya
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
PGADMIN_DEFAULT_PASSWORD=43lw9rj2
